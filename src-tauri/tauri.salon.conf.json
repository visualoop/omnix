{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Omnix Salon and Spa",
  "identifier": "co.ke.omnix.salon",
  "mainBinaryName": "Omnix Salon and Spa",
  "app": {
    "windows": [
      {
        "title": "Omnix Salon and Spa",
        "decorations": false,
        "shadow": false,
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "fullscreen": false
      }
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://omnix.co.ke/api/releases-latest?variant=salon&license={{current_version}}",
        "https://omnix.co.ke/api/releases-latest?variant=salon"
      ]
    }
  },
  "bundle": {
    "icon": [
      "icons/variants/salon/32x32.png",
      "icons/variants/salon/128x128.png",
      "icons/variants/salon/128x128@2x.png",
      "icons/variants/salon/icon.icns",
      "icons/variants/salon/icon.ico"
    ],
    "shortDescription": "Salon and spa POS with appointments and commissions",
    "longDescription": "Omnix Salon and Spa is the offline-first booking + POS app for Kenyan salons, barbershops, nail bars and spas. Appointment diary, staff skills and commissions, packages and memberships, back-bar stock, client history, KRA eTIMS, M-Pesa via Daraja and Paystack, multi-branch LAN sync. Pay once, own it forever.",
    "windows": {
      "nsis": {
        "installerIcon": "icons/variants/salon/icon.ico"
      }
    }
  }
}

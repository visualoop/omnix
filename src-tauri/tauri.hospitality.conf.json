{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Omnix Hospitality",
  "identifier": "co.ke.omnix.hospitality",
  "mainBinaryName": "Omnix Hospitality",
  "app": {
    "windows": [
      {
        "title": "Omnix Hospitality"
      }
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://omnix.co.ke/api/releases-latest?variant=hospitality&license={{current_version}}",
        "https://omnix.co.ke/api/releases-latest?variant=hospitality"
      ]
    }
  },
  "bundle": {
    "icon": [
      "icons/variants/hospitality/32x32.png",
      "icons/variants/hospitality/128x128.png",
      "icons/variants/hospitality/128x128@2x.png",
      "icons/variants/hospitality/icon.icns",
      "icons/variants/hospitality/icon.ico"
    ],
    "shortDescription": "Restaurant, bar & lodge POS for Kenya",
    "longDescription": "Omnix Hospitality is the offline-first POS app for Kenyan restaurants, bars, lodges, and hotels. Tables, KOT/kitchen tickets, recipes, menu engineering, room bookings, folios, KRA eTIMS, M-Pesa via Daraja and Paystack, multi-branch LAN sync. Pay once, own it forever.",
    "windows": {
      "nsis": {
        "installerIcon": "icons/variants/hospitality/icon.ico"
      }
    }
  }
}

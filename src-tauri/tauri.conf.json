{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Omnix",
  "version": "0.3.1",
  "identifier": "co.ke.omnix.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Omnix",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "decorations": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://omnix.co.ke/api/releases-latest?license={{current_version}}",
        "https://omnix.co.ke/api/releases-latest"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ1NTY3Mzk5RjdDMUYwMjUKUldRbDhNSDNtWE5XUmNlbG85RzRWUmlBc2lTRTNMUksvS3hIcldxOEdjODI1Y28rTkNPM0JkbXAK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["deb", "rpm", "appimage", "nsis", "msi", "dmg"],
    "category": "Business",
    "shortDescription": "ERP for Kenyan SMEs — pay once, use forever",
    "longDescription": "Omnix is an offline-first ERP platform for Kenyan SMEs — pharmacies, mini-marts, hardware shops, and hospitality (restaurants & hotels). KRA eTIMS compliance, SHA insurance claims, M-Pesa payments via Daraja and Paystack, multi-branch sync over LAN. Pay once, own the modules you choose forever.",
    "copyright": "© 2026 Omnix Technologies Ltd",
    "publisher": "Omnix",
    "homepage": "https://omnix.co.ke",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"],
        "section": "office"
      },
      "rpm": {
        "depends": ["webkit2gtk4.1", "gtk3"]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English"],
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": false,
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp",
        "compression": "lzma"
      },
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "omnix.co.ke"
    }
  }
}

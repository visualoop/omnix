{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Omnix Retail",
  "identifier": "co.ke.omnix.retail",
  "mainBinaryName": "Omnix Retail",
  "app": {
    "windows": [
      {
        "title": "Omnix Retail"
      }
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://omnix.co.ke/api/releases-latest?variant=retail&license={{current_version}}",
        "https://omnix.co.ke/api/releases-latest?variant=retail"
      ]
    }
  },
  "bundle": {
    "icon": [
      "icons/variants/retail/32x32.png",
      "icons/variants/retail/128x128.png",
      "icons/variants/retail/128x128@2x.png",
      "icons/variants/retail/icon.icns",
      "icons/variants/retail/icon.ico"
    ],
    "shortDescription": "Retail POS + inventory for Kenyan shops",
    "longDescription": "Omnix Retail is the offline-first POS and inventory app for Kenyan retail shops, mini-marts, and supermarkets. Brands, variants, layby, special orders, shrinkage, KRA eTIMS, M-Pesa via Daraja and Paystack, multi-branch LAN sync. Pay once, own it forever.",
    "windows": {
      "nsis": {
        "installerIcon": "icons/variants/retail/icon.ico"
      }
    }
  }
}

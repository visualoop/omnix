DATABASE_URL=mongodb://127.0.0.1/your-database-name
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Public site URL (used by sitemap/robots/canonical + JSON-LD). No trailing slash.
NEXT_PUBLIC_SERVER_URL=https://omnix.co.ke

# Analytics & Search Console (SEO)
NEXT_PUBLIC_GA_ID=                          # GA4 measurement ID, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=       # token from Search Console HTML-tag / meta method
